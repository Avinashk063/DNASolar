});

document.getElementById('pImageUrl').addEventListener('input', e => {
    const img = document.getElementById('imgPreview');
    if (e.target.value) { img.src = e.target.value; img.style.display = 'block'; }
    else img.style.display = 'none';
});

function editProduct(id) {
    const p = allProducts.find(x => x.productId === id);
    if (!p) return;
    document.getElementById('productModalTitle').textContent = 'Edit Product';
    document.getElementById('productId').value = p.productId;
    document.getElementById('pName').value = p.name;
    document.getElementById('pCategory').value = p.category || '';
    document.getElementById('pPrice').value = p.price;
    document.getElementById('pOriginalPrice').value = p.originalPrice || '';
    document.getElementById('pInStock').value = p.inStock ? 'true' : 'false';
    document.getElementById('pDescription').value = p.description || '';
    document.getElementById('pImageUrl').value = p.imageUrl || '';
    const img = document.getElementById('imgPreview');
    if (p.imageUrl) { img.src = p.imageUrl; img.style.display = 'block'; } else img.style.display = 'none';
    document.getElementById('pImageFile').value = '';
    openModal('productModal');
}

async function saveProduct(e) {
    e.preventDefault();
    const btn = document.getElementById('saveProductBtn');
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

    const id = document.getElementById('productId').value;
    const fileInput = document.getElementById('pImageFile');
    const hasFile = fileInput.files.length > 0;

    try {
        let res;
        if (hasFile) {
            // multipart upload
            const fd = new FormData();
            fd.append('name',          document.getElementById('pName').value);
            fd.append('category',      document.getElementById('pCategory').value);
            fd.append('price',         document.getElementById('pPrice').value);
            fd.append('originalPrice', document.getElementById('pOriginalPrice').value || '');
            fd.append('description',   document.getElementById('pDescription').value);
            fd.append('imageUrl',      document.getElementById('pImageUrl').value || '');
            fd.append('inStock',       document.getElementById('pInStock').value);
            fd.append('image',         fileInput.files[0]);

            if (id) {
                // edit with file: upload image first, then PUT JSON
                const upRes = await fetch('/api/admin/upload', { method:'POST', body: fd, credentials:'include' });
                const upData = await upRes.json();
                res = await fetch(`/api/admin/products/${id}`, {
                    method:'PUT', credentials:'include',
                    headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({
                        name: document.getElementById('pName').value,
                        category: document.getElementById('pCategory').value,
                        price: parseFloat(document.getElementById('pPrice').value),
                        originalPrice: parseFloat(document.getElementById('pOriginalPrice').value) || null,
                        description: document.getElementById('pDescription').value,
                        imageUrl: upData.url,
                        inStock: document.getElementById('pInStock').value === 'true'
                    })
                });
            } else {
                res = await fetch('/api/admin/products', { method:'POST', body: fd, credentials:'include' });
            }
        } else {
            const payload = {
                name:          document.getElementById('pName').value,
                category:      document.getElementById('pCategory').value,
                price:         parseFloat(document.getElementById('pPrice').value),
                originalPrice: parseFloat(document.getElementById('pOriginalPrice').value) || null,
                description:   document.getElementById('pDescription').value,
                imageUrl:      document.getElementById('pImageUrl').value || 'https://via.placeholder.com/500?text=No+Image',
                inStock:       document.getElementById('pInStock').value === 'true'
            };
            if (id) {
                res = await fetch(`/api/admin/products/${id}`, { method:'PUT', credentials:'include', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
            } else {
                res = await fetch('/api/admin/products', { method:'POST', credentials:'include', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
            }
        }

        if (!res.ok) { const t = await res.text(); throw new Error(t || res.status); }
        closeModal('productModal');
        toast(id ? 'Product updated!' : 'Product added!', 'success');
        localStorage.setItem('product-updated', String(Date.now()));
        await loadProducts();
    } catch(err) {
        toast('Error: ' + err.message, 'error');
    } finally {
        btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Save Product';
    }
}

async function deleteProduct(id, name) {
    if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
    try {
        const res = await fetch(`/api/admin/products/${id}`, { method:'DELETE', credentials:'include' });
        if (!res.ok) throw new Error(await res.text());
        toast('Product deleted.', 'success');
        localStorage.setItem('product-updated', String(Date.now()));
        await loadProducts();
    } catch(e) { toast('Delete failed: ' + e.message, 'error'); }
}

// ── CATEGORIES ────────────────────────────────────────────
async function loadCategories() {
    const tbody = document.getElementById('categoriesTable');
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center"><i class="fas fa-spinner fa-spin"></i> Loading...</td></tr>';
    try {
        const res = await fetch('/api/admin/categories', { credentials: 'include' });
        if (!res.ok) throw new Error(res.status);
        allCategories = await res.json();
        // also ensure products are loaded so we can show product counts
        if (!allProducts.length) {
            const pr = await fetch('/api/admin/products', { credentials: 'include' });
            if (pr.ok) allProducts = await pr.json();
        }
        renderCategories(allCategories);
        refreshCategoryDatalist();
    } catch(e) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;color:#ef4444">Failed: ${e.message}</td></tr>`;
    }
}

function renderCategories(list) {
    const tbody = document.getElementById('categoriesTable');
    if (!list.length) {
        tbody.innerHTML = '<tr><td colspan="4"><div class="empty-state"><i class="fas fa-tags"></i>No categories yet.</div></td></tr>';
        return;
    }
    tbody.innerHTML = list.map((c, i) => {
        const prodCount = allProducts.filter(p => (p.category||'').toLowerCase() === c.name.toLowerCase()).length;
        return `<tr>
            <td data-label="#">${i + 1}</td>
            <td data-label="Category" class="strong">${c.name}</td>
            <td data-label="Products">
                <span class="badge ${prodCount > 0 ? 'badge-success' : 'badge-default'}">${prodCount} product${prodCount !== 1 ? 's' : ''}</span>
            </td>
            <td data-label="Actions"><div class="action-btns">
                <button class="btn btn-sm btn-secondary" onclick="editCategory(${c.categoryId}, '${c.name.replace(/'/g,"\\'")}')"><i class="fas fa-edit"></i> Rename</button>
                <button class="btn btn-sm btn-danger" onclick="tryDeleteCategory(${c.categoryId},'${c.name.replace(/'/g,"\\'")}',${prodCount})"><i class="fas fa-trash"></i></button>
            </div></td>
        </tr>`;
    }).join('');
}

document.getElementById('categorySearch').addEventListener('input', e => {
    const q = e.target.value.toLowerCase();
    renderCategories(allCategories.filter(c => c.name.toLowerCase().includes(q)));
});

function openAddCategory() {
    document.getElementById('categoryModalTitle').textContent = 'Add Category';
    document.getElementById('categoryForm').reset();
    document.getElementById('editCategoryId').value = '';
    openModal('categoryModal');
}

function editCategory(id, name) {
    document.getElementById('categoryModalTitle').textContent = 'Rename Category';
    document.getElementById('editCategoryId').value = id;
    document.getElementById('editCategoryName').value = name;
    openModal('categoryModal');
}

async function saveCategory(e) {
    e.preventDefault();
    const id   = document.getElementById('editCategoryId').value;
    const name = document.getElementById('editCategoryName').value.trim();
    if (!name) return;
    try {
        const url    = id ? `/api/admin/categories/${id}` : '/api/admin/categories';
        const method = id ? 'PUT' : 'POST';
        const res = await fetch(url, {
            method, credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name })
        });
        if (!res.ok) {
            const msg = await res.text();
            throw new Error(msg || res.status);
        }
        closeModal('categoryModal');
        toast(id ? 'Category renamed!' : 'Category added!', 'success');
        await loadCategories();
        // keep product table datalist + cached products in sync
        await loadProducts();
    } catch(err) { toast('Error: ' + err.message, 'error'); }
}

function tryDeleteCategory(id, name, prodCount) {
    if (prodCount > 0) {
        document.getElementById('catBlockedMsg').innerHTML =
            `<strong>"${name}"</strong> cannot be deleted because it has <strong>${prodCount} product${prodCount !== 1 ? 's' : ''}</strong> assigned to it.`;
        openModal('catBlockedModal');
        return;
    }
    deleteCategory(id, name);
}

async function deleteCategory(id, name) {
    if (!confirm(`Delete category "${name}"? This cannot be undone.`)) return;
    try {
        const res = await fetch(`/api/admin/categories/${id}`, { method: 'DELETE', credentials: 'include' });
        if (!res.ok) throw new Error(await res.text());
        toast('Category deleted.', 'success');
        await loadCategories();
        refreshCategoryDatalist();
    } catch(e) { toast('Delete failed: ' + e.message, 'error'); }
}

