        refreshCategoryDatalist();
    } catch(e) {
        tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:#ef4444">Failed to load products: ${e.message}</td></tr>`;
    }
}

// Rebuild the datalist used in the product form from allCategories + any extra from allProducts
function refreshCategoryDatalist() {
    const cats = new Set([
        ...allCategories.map(c => c.name),
        ...allProducts.map(p => p.category).filter(Boolean)
    ]);
    document.getElementById('categoryList').innerHTML =
        [...cats].sort().map(c => `<option value="${c}">`).join('');
}

function renderProducts(list) {
    const tbody = document.getElementById('productsTable');
    if (!list.length) { tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fas fa-box-open"></i>No products found.</div></td></tr>'; return; }
    tbody.innerHTML = list.map(p => `
        <tr>
            <td data-label=""><img src="${p.imageUrl || 'https://via.placeholder.com/48?text=No+Img'}" class="prod-img" onerror="this.src='https://via.placeholder.com/48?text=No+Img'"></td>
            <td data-label="Name" class="strong">${p.name}</td>
            <td data-label="Category">${p.category || '-'}</td>
            <td data-label="Price" class="strong">${money(p.price)}</td>
            <td data-label="Stock"><span class="badge ${p.inStock ? 'badge-success' : 'badge-danger'}">${p.inStock ? 'In Stock' : 'Out of Stock'}</span></td>
            <td data-label="Actions"><div class="action-btns">
                <button class="btn btn-sm btn-secondary" onclick="editProduct(${p.productId})"><i class="fas fa-edit"></i> Edit</button>
