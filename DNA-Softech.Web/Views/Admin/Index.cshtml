async function viewOrder(id) {
    const o = allOrders.find(x => x.id === id);
    if (!o) return;

    let itemsHtml = '';
    try {
        const items = typeof o.itemsJson === 'string' ? JSON.parse(o.itemsJson) : (o.itemsJson || []);
        if (items.length) {
            itemsHtml = `<table class="order-items-mini" style="margin-top:8px">
                <thead><tr><th>Product ID</th><th>Qty</th></tr></thead>
                <tbody>${items.map(i => `<tr><td>#${i.productId}</td><td>${i.quantity}</td></tr>`).join('')}</tbody>
            </table>`;
        }
    } catch { /* ignore */ }

    const cls = o.status === 'Confirmed' ? 'badge-success' : o.status === 'Cancelled' ? 'badge-danger' : 'badge-warning';
    document.getElementById('orderModalBody').innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px">
            <div><label style="font-size:12px;color:#64748b;font-weight:600">ORDER ID</label><div class="strong">#${o.id}</div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">STATUS</label><div><span class="badge ${cls}">${o.status}</span></div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">CUSTOMER</label><div>${o.customerName || '-'}</div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">EMAIL</label><div style="font-size:13px">${o.customerEmail || '-'}</div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">PHONE</label><div>${o.customerPhone || '-'}</div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">PAYMENT</label><div>${o.paymentMethod || '-'}</div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">TOTAL</label><div class="strong" style="font-size:18px;color:#10b981">${money(o.total)}</div></div>
            <div><label style="font-size:12px;color:#64748b;font-weight:600">DATE</label><div>${o.createdAt ? new Date(o.createdAt).toLocaleString('en-IN') : '-'}</div></div>
            <div style="grid-column:span 2"><label style="font-size:12px;color:#64748b;font-weight:600">ADDRESS</label><div>${o.customerAddress || '-'}</div></div>
        </div>
        <div><label style="font-size:12px;color:#64748b;font-weight:600">ITEMS</label>${itemsHtml || '<div style="color:#94a3b8;font-size:13px">No items data</div>'}</div>`;

    const actDiv = document.getElementById('orderModalActions');
    actDiv.innerHTML = '';
    if (o.status !== 'Confirmed' && o.status !== 'Cancelled') {
        const btn = document.createElement('button');
        btn.className = 'btn btn-primary';
        btn.innerHTML = '<i class="fas fa-check"></i> Confirm Order';
        btn.onclick = async () => { await confirmOrder(o.id); closeModal('orderModal'); };
        actDiv.appendChild(btn);
    }
    const close = document.createElement('button');
    close.className = 'btn btn-secondary'; close.textContent = 'Close';
    close.onclick = () => closeModal('orderModal');
    actDiv.appendChild(close);

    openModal('orderModal');
}

async function confirmOrder(id) {
