@{
    ViewData["Title"] = "Product Details — DNA Softech";
    Layout = null;
    var productId = ViewData["ProductId"] ?? 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Product Details — DNA Softech</title>
    <meta name="description" content="Premium solar products — DNA Softech" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-detail.css" asp-append-version="true" />
</head>
<body>

    <!-- ===== HEADER (same as shop page) ===== -->
    <header class="header">
        <div class="header-top">
            <div class="container-fluid">
                <a href="/" class="logo">
                    <img src="~/img/BrandLogo.png" alt="DNA Softech" class="brand-logo-img" />
                    <span class="brand-name">DNA Softech</span>
                </a>

                <div class="search-section">
                    <div class="search-bar">
                        <input type="text" id="searchInput" placeholder="Search for solar panels, inverters, batteries..." />
                        <button class="search-btn" onclick="window.location.href='/Shop?q='+document.getElementById('searchInput').value"><i class="fas fa-search"></i></button>
                    </div>
                </div>

                <div class="header-actions">
                    <a href="/Shop/Orders" id="myOrdersLink" class="header-btn" style="display:none; text-decoration:none;">
                        <span class="header-icon-wrap"><i class="fas fa-box"></i></span>
                        <span class="header-btn-label">Orders</span>
                    </a>
                    <a href="/Admin" id="adminLink" class="header-btn header-btn--admin" style="display:none; text-decoration:none;">
                        <span class="header-icon-wrap"><i class="fas fa-shield-alt"></i></span>
                        <span class="header-btn-label">Admin</span>
                    </a>
                    <button class="header-btn" id="wishlistBtn">
                        <span class="header-icon-wrap"><i class="far fa-heart"></i></span>
                        <span class="header-btn-label">Wishlist</span>
                        <span class="badge" id="wishlistCount">0</span>
                    </button>
                    <button class="header-btn" id="cartToggle">
                        <span class="header-icon-wrap"><i class="fas fa-shopping-cart"></i></span>
                        <span class="header-btn-label">Cart</span>
                        <span class="badge" id="cartCount">0</span>
                    </button>
                    <button class="header-btn header-btn--user" id="userBtn">
                        <span class="header-icon-wrap user-avatar" id="userAvatar"><i class="far fa-user"></i></span>
                        <span class="header-btn-label" id="userName">Account</span>
                        <span id="adminBadge" class="badge badge--admin" style="display:none;">Admin</span>
                    </button>
                </div>
            </div>
        </div>

        <nav class="category-nav">
            <div id="categoryContainer" class="container-fluid">
                <!-- Categories loaded by shop.js -->
            </div>
        </nav>
    </header>

    <div id="miniToast" class="mini-toast" aria-hidden="true"></div>

    <!-- ===== PRODUCT PAGE CONTENT ===== -->
    <div class="product-page">
        <nav class="breadcrumbs" id="breadcrumbs">
            <a href="/Shop">Shop</a>
            <i class="fas fa-chevron-right"></i>
            <span id="breadcrumb-category">Category</span>
            <i class="fas fa-chevron-right"></i>
            <span id="breadcrumb-product">Product</span>
        </nav>

        <div id="productContainer">
            <div style="text-align:center; padding:100px;">
                <i class="fas fa-circle-notch fa-spin" style="font-size:40px; color:var(--primary-color);"></i>
                <p style="margin-top:1rem;color:#64748b;">Loading product details…</p>
            </div>
        </div>
    </div>

    <!-- ===== LIGHTBOX ===== -->
    <div id="lightbox" class="lightbox" onclick="this.style.display='none'">
        <img id="lightboxImg" src="" alt="Zoomed view" />
    </div>

    <!-- ===== WISHLIST PANEL ===== -->
    <aside id="wishlistPanel" class="wishlist-panel side-panel">
        <div class="cart-header">
            <h3><i class="fas fa-heart"></i> My Wishlist</h3>
            <button class="close-cart" id="closeWishlist"><i class="fas fa-times"></i></button>
        </div>
        <div class="cart-body">
            <div id="emptyWishlist" class="panel-empty-state">
                <i class="far fa-heart"></i>
                <p class="panel-empty-title">Your wishlist is empty</p>
                <p class="panel-empty-sub">Save products you love to find them easily later</p>
            </div>
            <ul id="wishlistItems" class="cart-items hidden"></ul>
        </div>
    </aside>

    <!-- ===== CART PANEL ===== -->
    <aside id="cartPanel" class="cart-panel side-panel">
        <div class="cart-header">
            <h3><i class="fas fa-shopping-cart"></i> My Cart</h3>
            <button class="close-cart" id="closeCart"><i class="fas fa-times"></i></button>
        </div>
        <div class="cart-body">
            <div id="emptyCart" class="panel-empty-state">
                <i class="fas fa-shopping-cart"></i>
                <p class="panel-empty-title">Your cart is empty</p>
                <p class="panel-empty-sub">Add products to get started</p>
            </div>
            <ul id="cartItems" class="cart-items hidden"></ul>
        </div>
        <div class="cart-footer">
            <div class="cart-total-row">
                <span>Subtotal</span>
                <span id="cartSubtotal">₹0.00</span>
            </div>
            <div class="cart-total-row cart-total-row--main">
                <span>Total (incl. taxes)</span>
                <span id="cartTotal">₹0.00</span>
            </div>
            <button class="btn-checkout-cta" id="checkoutBtn">
                <i class="fas fa-lock"></i> Proceed to Checkout
            </button>
            <button class="btn-continue-shopping" id="closeCartBtn">Continue Shopping</button>
        </div>
    </aside>

    <!-- ===== USER MODAL ===== -->
    <div id="userModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="userModalTitle">
        <div class="modal-content modal-content--sm">
            <div class="modal-header">
                <h3 id="userModalTitle">My Account</h3>
                <button class="modal-close" id="closeUserModal" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div id="userProfile" class="hidden">
                    <div id="profileViewSection">
                        <div class="profile-hero">
                            <div class="profile-avatar-lg" id="profileAvatar">U</div>
                            <div>
                                <h4 id="profileName" class="profile-name">User Name</h4>
                                <p id="profileEmail" class="profile-email">user@email.com</p>
                            </div>
                        </div>
                        <div class="profile-actions">
                            <button id="editProfileBtn" class="btn-outline-primary"><i class="fas fa-edit"></i> Edit Profile</button>
                            <button id="logoutBtn" class="btn-danger-outline"><i class="fas fa-sign-out-alt"></i> Logout</button>
                        </div>
                    </div>
                    <div id="profileEditSection" class="hidden" style="margin-top:.5rem;">
                        <p style="font-weight:700;font-size:.95rem;margin-bottom:.9rem;color:var(--dark-navy,#1e293b);">
                            <i class="fas fa-user-edit" style="color:var(--primary-color);margin-right:.4rem;"></i>Edit Profile
                        </p>
                        <div id="editProfileError" style="display:none;background:#fee2e2;color:#b91c1c;padding:.55rem .75rem;border-radius:8px;font-size:.82rem;margin-bottom:.75rem;"></div>
                        <div class="form-group" style="margin-bottom:.75rem;">
                            <label style="font-size:.8rem;font-weight:600;color:#64748b;display:block;margin-bottom:.3rem;">Full Name *</label>
                            <input type="text" id="editName" class="form-control" placeholder="Your full name" style="width:100%;" />
                        </div>
                        <div class="form-group" style="margin-bottom:.75rem;">
                            <label style="font-size:.8rem;font-weight:600;color:#64748b;display:block;margin-bottom:.3rem;">Mobile</label>
                            <input type="tel" id="editPhone" class="form-control" placeholder="+91 98765 43210" style="width:100%;" />
                        </div>
                        <div class="form-group" style="margin-bottom:.9rem;">
                            <label style="font-size:.8rem;font-weight:600;color:#64748b;display:block;margin-bottom:.3rem;">Address</label>
                            <input type="text" id="editAddress" class="form-control" placeholder="Street, City" style="width:100%;" />
                        </div>
                        <div style="display:flex;gap:.6rem;">
                            <button id="saveProfileBtn" class="btn-primary" style="flex:1;">Save</button>
                            <button id="cancelEditBtn" class="btn-outline-primary" style="flex:1;">Cancel</button>
                        </div>
                    </div>
                </div>
                <div id="authForms">
                    <div class="auth-tabs">
                        <button class="auth-tab active" id="showLogin">Sign In</button>
                        <button class="auth-tab" id="showRegister">Create Account</button>
                    </div>
                    <form id="loginForm" class="auth-form">
                        <div class="form-group">
                            <label>Email Address</label>
                            <div class="input-icon-wrap">
                                <i class="fas fa-envelope input-icon"></i>
                                <input type="email" name="email" placeholder="your@email.com" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Password</label>
                            <div class="input-icon-wrap">
                                <i class="fas fa-lock input-icon"></i>
                                <input type="password" name="password" placeholder="••••••••" required />
                            </div>
                        </div>
                        <button type="submit" class="btn-primary btn-block">Sign In <i class="fas fa-arrow-right"></i></button>
                    </form>
                    <form id="registerForm" class="auth-form hidden">
                        <!-- Step 1: basic info -->
                        <div id="regStep1">
                            <div class="form-group">
                                <label>Full Name</label>
                                <div class="input-icon-wrap">
                                    <i class="fas fa-user input-icon"></i>
                                    <input type="text" name="name" placeholder="John Doe" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Email Address</label>
                                <div class="input-icon-wrap">
                                    <i class="fas fa-envelope input-icon"></i>
                                    <input type="email" name="email" placeholder="your@email.com" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Password</label>
                                <div class="input-icon-wrap">
                                    <i class="fas fa-lock input-icon"></i>
                                    <input type="password" name="password" placeholder="Create a strong password" />
                                </div>
                            </div>
                        </div>
                        <!-- Step 2: OTP (hidden until code is sent) -->
                        <div id="otpSection" style="display:none">
                            <div class="otp-info-box">
                                <i class="fas fa-envelope-circle-check" style="color:#10b981;font-size:1.2rem;"></i>
                                <span id="otpSentMsg" style="font-size:.85rem;color:#334155;">OTP sent — check your inbox</span>
                            </div>
                            <div class="form-group">
                                <label>6-Digit OTP</label>
                                <div class="input-icon-wrap">
                                    <i class="fas fa-shield-halved input-icon"></i>
                                    <input type="text" name="otp" id="otpInput" maxlength="6" placeholder="_ _ _ _ _ _"
                                           inputmode="numeric" autocomplete="one-time-code"
                                           style="letter-spacing:.35rem;font-size:1.1rem;font-weight:700;text-align:center;" />
                                </div>
                            </div>
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem;font-size:.78rem;">
                                <span id="otpTimer" style="color:#64748b;"></span>
                                <button type="button" id="resendOtpBtn" style="display:none;background:none;border:none;color:#4f46e5;font-weight:600;cursor:pointer;font-size:.78rem;">Resend OTP</button>
                            </div>
                        </div>
                        <button type="submit" class="btn-primary btn-block" id="registerSubmitBtn">
                            Send Verification Code <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>
    <div id="overlay" class="overlay"></div>

    <script src="~/js/ui.js" asp-append-version="true"></script>
    <script src="~/js/shop.js" asp-append-version="true"></script>
    <script>
            const CURRENT_PRODUCT_ID = @productId;
    </script>
    <script src="~/js/product-detail.js" asp-append-version="true"></script>
</body>
</html>
