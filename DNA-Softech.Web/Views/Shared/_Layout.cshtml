<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "DNA Softech Shop")</title>
    <meta name="description" content="@(ViewData["Description"] ?? "DNA Softech – Premium Solar Products for Home and Business")" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />

    <!-- Site-wide CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Page-specific CSS (optional section) -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ─── Navigation ─────────────────────────────────────────────────── -->
    <nav class="navbar" id="main-navbar">
        <div class="navbar-container">
            <!-- Brand -->
            <a href="/" class="navbar-brand" id="nav-home-link">
                <img src="~/img/BrandLogo.png" alt="DNA Softech" style="height:36px;width:36px;object-fit:contain;border-radius:8px;" />
                <span>DNA Softech</span>
            </a>

            <!-- Navigation links -->
            <ul class="navbar-links" id="navbar-links">
                <li><a href="/" class="nav-link" id="nav-link-home">Home</a></li>
                <li><a href="/Shop" class="nav-link" id="nav-link-shop">Shop</a></li>
                <li><a href="/Shop/Orders" class="nav-link" id="nav-link-orders">My Orders</a></li>
            </ul>

            <!-- Right-side actions -->
            <div class="navbar-actions">
                <!-- Cart button with badge -->
                <button class="cart-btn" id="cart-toggle-btn" aria-label="Open cart" title="View Cart">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="9" cy="21" r="1" />
                        <circle cx="20" cy="21" r="1" />
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                    </svg>
                    <span class="cart-badge" id="cart-badge" style="display:none">0</span>
                </button>

                <!-- User menu — shown/hidden by site.js based on auth state -->
                <div class="user-menu" id="user-menu-anon">
                    <a href="/Account/Login" class="btn btn-outline" id="nav-login-btn">Login</a>
                </div>
                <div class="user-menu" id="user-menu-auth" style="display:none">
                    <div class="dropdown" id="user-dropdown">
                        <button class="dropdown-trigger" id="user-dropdown-btn" aria-haspopup="true" aria-expanded="false">
                            <span class="nav-avatar" id="nav-user-avatar">U</span>
                            <span id="nav-user-name">Account</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <polyline points="6 9 12 15 18 9" />
                            </svg>
                        </button>
                        <ul class="dropdown-menu" id="user-dropdown-menu" role="menu">
                            <li role="menuitem"><a href="/Account/Profile" id="nav-profile-link">My Profile</a></li>
                            <li role="menuitem"><a href="/Shop/Orders" id="nav-orders-link">My Orders</a></li>
                            <li role="menuitem" id="nav-admin-item" style="display:none">
                                <a href="/Admin" id="nav-admin-link">Admin Dashboard</a>
                            </li>
                            <li role="separator" class="dropdown-divider"></li>
                            <li role="menuitem">
                                <form method="post" action="/Account/Logout" id="logout-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-logout-btn" id="nav-logout-btn">Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- ─── Cart slide-out panel ────────────────────────────────────────── -->
    <div class="cart-overlay" id="cart-overlay" aria-hidden="true"></div>
    <aside class="cart-panel" id="cart-panel" aria-label="Shopping cart" aria-hidden="true">
        <div class="cart-panel-header">
            <h2 class="cart-panel-title">Your Cart</h2>
            <button class="cart-close-btn" id="cart-close-btn" aria-label="Close cart">&times;</button>
        </div>
        <div class="cart-panel-body" id="cart-panel-body">
            <p class="cart-empty-msg" id="cart-empty-msg">Your cart is empty.</p>
            <ul class="cart-items-list" id="cart-items-list"></ul>
        </div>
        <div class="cart-panel-footer" id="cart-panel-footer" style="display:none">
            <div class="cart-total">
                Total: <strong id="cart-total-value">₹0</strong>
            </div>
            <a href="/Shop/Checkout" class="btn btn-primary btn-block" id="cart-checkout-btn">Proceed to Checkout</a>
        </div>
    </aside>

    <!-- ─── Toast notification ──────────────────────────────────────────── -->
    <div class="toast-container" id="toast-container" aria-live="polite"></div>

    <!-- ─── Page content ────────────────────────────────────────────────── -->
    <main id="main-content">
        @RenderBody()
    </main>

    <!-- ─── Footer ──────────────────────────────────────────────────────── -->
    <footer class="site-footer" id="site-footer">
        <div class="footer-container">
            <div class="footer-brand">
                <a href="/" class="footer-logo-wrap">
                    <img src="~/img/BrandLogo.png" alt="DNA Softech" class="footer-logo-img" />
                    <span class="footer-logo">DNA Softech</span>
                </a>
                <p class="footer-tagline">Empowering India with clean, affordable solar energy solutions for homes and businesses.</p>
                <div class="footer-socials">
                    <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
            <div class="footer-links">
                <div class="footer-col">
                    <h4>Shop</h4>
                    <ul>
                        <li><a href="/Shop">All Products</a></li>
                        <li><a href="/Shop?category=inverters">Inverters</a></li>
                        <li><a href="/Shop?category=panels">Solar Panels</a></li>
                        <li><a href="/Shop?category=batteries">Batteries</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Account</h4>
                    <ul>
                        <li><a href="/Account/Login">Login</a></li>
                        <li><a href="/Account/Register">Register</a></li>
                        <li><a href="/Shop/Orders">My Orders</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="mailto:support@dnasoftech.com"><i class="fas fa-envelope" style="margin-right:.4rem;font-size:.8rem;"></i>support&#64;dnasoftech.com</a></li>
                        <li><a href="tel:+919876543210"><i class="fas fa-phone" style="margin-right:.4rem;font-size:.8rem;"></i>+91 98765 43210</a></li>
                        <li><a href="#"><i class="fas fa-map-marker-alt" style="margin-right:.4rem;font-size:.8rem;"></i>Mumbai, India</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year DNA Softech. All rights reserved. &nbsp;|&nbsp; Made with <i class="fas fa-heart" style="color:#ef4444;"></i> in India</p>
        </div>
    </footer>

    <!-- ─── Core JS ──────────────────────────────────────────────────────── -->
    <!-- site.js initialises auth state, cart badge, dropdown, and toast -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Page-specific scripts (optional section) -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
